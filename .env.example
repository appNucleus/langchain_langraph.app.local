# Existing host binding for Caddy/server setup
HOST_BIND=127.0.0.1
APP_PORT=8001

# Application
APP_NAME=LangChain LangGraph App
ENVIRONMENT=local
LOG_LEVEL=INFO
API_KEY=
CORS_ALLOW_ORIGINS=*

# Run identity and durable outcomes
# Canonical namespace for newly created execution checkpoints.
RUN_CHECKPOINT_NAMESPACE=execution-state-v1
RUN_STATE_SCHEMA_VERSION=1
RUN_REQUEST_HASH_VERSION=1
RESUME_TOKEN_SECRET=
RESUME_TOKEN_TTL_SECONDS=3600
RESUME_TOKEN_ACTIVE_KEY_ID=primary
# Optional rotation key ring. When set, the active key ID must exist in this JSON object.
# RESUME_TOKEN_KEYS_JSON={"primary":"replace-me","previous":"replace-me-too"}
SAME_CONVERSATION_POLICY=reject
RUN_REPOSITORY_BACKEND=memory
RUN_LEASE_TTL_SECONDS=30
RUN_LEASE_HEARTBEAT_SECONDS=10

# Ollama
LLM_BACKEND=ollama
OLLAMA_BASE_URL=http://ollama.home.arpa:11434
OLLAMA_TEMPERATURE=0.2
OLLAMA_NUM_PREDICT=2048
OLLAMA_NUM_CTX=8192
STRUCTURED_OUTPUT_RESERVE_TOKENS=1536
STRUCTURED_PROMPT_CHARS_PER_TOKEN=3.0
OLLAMA_THINK=false
OLLAMA_TIMEOUT_SECONDS=180
OLLAMA_CONNECT_TIMEOUT_SECONDS=10
OLLAMA_POOL_TIMEOUT_SECONDS=30
OLLAMA_MAX_CONNECTIONS=20
OLLAMA_MAX_KEEPALIVE_CONNECTIONS=10
OLLAMA_MAX_CONCURRENCY=2
OLLAMA_HEAVY_MAX_CONCURRENCY=1
OLLAMA_KEEP_ALIVE=10m
HTTP_KEEPALIVE_EXPIRY_SECONDS=30

# Model roles
MODEL_PLANNER=qwen3.5:4b
MODEL_SIMPLE=qwen3.5:2b
MODEL_GENERAL=qwen3.5:4b
MODEL_SEARCH=qwen3.5:9b
MODEL_REASONING=deepseek-r1:8b
MODEL_FAST_REASONING=phi4-mini-reasoning:latest
MODEL_HEAVY=gemma4:26b-a4b-it-qat
MODEL_SYNTHESIS=gemma4:12b-it-qat
MODEL_WRITER=gemma4:e4b-it-qat
MODEL_CLASSIFIER=gemma4:e2b-it-qat
MODEL_VISION=qwen3-vl:4b
MODEL_FALLBACK=granite3.3:8b
EMBEDDING_MODEL=qwen3-embedding:0.6b

# MCP
MCP_ENABLED=true
MCP_SERVER_URL=https://mcp.home.arpa/mcp
MCP_VERIFY_TLS=false
MCP_FOLLOW_REDIRECTS=true
MCP_TIMEOUT_SECONDS=60
MCP_CONNECT_TIMEOUT_SECONDS=10
MCP_READ_TIMEOUT_SECONDS=60
MCP_WRITE_TIMEOUT_SECONDS=60
MCP_POOL_TIMEOUT_SECONDS=20
MCP_MAX_CONNECTIONS=30
MCP_MAX_KEEPALIVE_CONNECTIONS=15
MCP_MAX_CONCURRENCY=6
MCP_SESSION_ENABLED=true
MCP_INITIALIZE_ON_STARTUP=true
MCP_PROTOCOL_VERSION=2025-06-18
MCP_CLIENT_NAME=langchain-langraph-app

# Inventory
INVENTORY_CACHE_TTL_SECONDS=60
INVENTORY_STALE_IF_ERROR_SECONDS=300

# Worker, research, verification, and replanning loop
AGENT_MAX_ITERATIONS=4
AGENT_MAX_RESEARCH_ROUNDS=2
AGENT_MAX_REPLANS=1
AGENT_MAX_CONTEXT_CHARS=16000
RESEARCH_MAX_QUERIES_PER_TASK=3
RESEARCH_MAX_EVIDENCE_CHARS_PER_QUERY=6000

# Global budgets and safeguards
EXECUTION_MAX_DURATION_SECONDS=180
EXECUTION_MAX_MODEL_CALLS=8
EXECUTION_MAX_TOOL_CALLS=10
EXECUTION_MAX_VERIFIER_ROUNDS=3
STATE_TTL_SECONDS=3600
STATE_MAX_SESSIONS=1000
STATE_MAX_HISTORY_MESSAGES=30
SIDE_EFFECT_POLICY_ENABLED=true
REAL_STREAMING_ENABLED=true
DETAILED_TRACING_ENABLED=true
EXPOSE_INTERNAL_HEALTH_DETAILS=false

# Persistence
STATE_BACKEND=memory
CHECKPOINT_BACKEND=memory
ARTIFACT_BACKEND=disabled

# PostgreSQL + pgvector from appNucleus/dbs.local at dbs.home.arpa:5432
# dbs.local creates database langgraph_app for user langgraph_user.
DATABASE_URL=postgresql://langgraph_user:change_me_postgres_2026@dbs.home.arpa:5432/langgraph_app
POSTGRES_POOL_MIN_SIZE=1
POSTGRES_POOL_MAX_SIZE=10
POSTGRES_COMMAND_TIMEOUT_SECONDS=30
POSTGRES_AUTO_SETUP=true

# Redis from appNucleus/dbs.local at dbs.home.arpa:6379
REDIS_URL=redis://default:change_me_redis_2026@dbs.home.arpa:6379/0
REDIS_KEY_PREFIX=langgraph
REDIS_MAX_CONNECTIONS=20

# MinIO S3 API from appNucleus/dbs.local at dbs.home.arpa:9000
MINIO_ENDPOINT=dbs.home.arpa:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_minio_2026
MINIO_BUCKET=langgraph-app
MINIO_SECURE=false

# Neo4j Bolt from appNucleus/dbs.local at dbs.home.arpa:7687
# One application-scoped async driver owns the bounded Bolt connection pool.
NEO4J_ENABLED=false
NEO4J_URI=bolt://dbs.home.arpa:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change_me_neo4j_2026
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_POOL_SIZE=20
NEO4J_CONNECTION_ACQUISITION_TIMEOUT_SECONDS=30
NEO4J_CONNECTION_TIMEOUT_SECONDS=10
NEO4J_MAX_CONNECTION_LIFETIME_SECONDS=3600
NEO4J_KEEP_ALIVE=true

# Recommended durable multi-worker local deployment:
# STATE_BACKEND=postgres
# RUN_REPOSITORY_BACKEND=postgres
# CHECKPOINT_BACKEND=postgres
# ARTIFACT_BACKEND=minio
# NEO4J_ENABLED=true
# PERSISTENCE_REQUIRED=true
# RESUME_TOKEN_KEYS_JSON={"primary":"replace-with-a-long-random-secret"}

# Dependency startup policy
OLLAMA_REQUIRED=true
MCP_REQUIRED=false
PERSISTENCE_REQUIRED=false
ARTIFACT_STORAGE_REQUIRED=false
PERSISTENCE_HEALTH_TIMEOUT_SECONDS=5

# Final synthesized-answer verification
FINAL_VERIFICATION_ENABLED=true
FINAL_MAX_REVISION_ROUNDS=1
