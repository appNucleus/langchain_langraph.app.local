# Existing host binding. Keep this for your current Caddy/server setup.
HOST_BIND=127.0.0.1
APP_PORT=8001

# App metadata
APP_NAME=LangChain LangGraph App
APP_VERSION=0.4.0
ENVIRONMENT=local
LOG_LEVEL=INFO

# Optional public API protection.
# If API_KEY is empty, /api/chat and /api/inventory are open to whoever can reach the service.
API_KEY=

# LLM backend.
LLM_BACKEND=ollama
OLLAMA_BASE_URL=http://ollama.home.arpa:11434
OLLAMA_TEMPERATURE=0.1
OLLAMA_TIMEOUT_SECONDS=240
OLLAMA_NUM_PREDICT=2048
OLLAMA_STREAM_NUM_PREDICT=2048
OLLAMA_KEEP_ALIVE=10m
OLLAMA_THINK=false

# Ollama model roles. These are resolved against live GET /api/tags inventory.
MODEL_PLANNER=qwen3.5:4b
MODEL_SIMPLE=qwen3.5:2b
MODEL_GENERAL=qwen3.5:4b
MODEL_SEARCH=qwen3.5:9b
MODEL_REASONING=phi4-mini-reasoning:latest
MODEL_HEAVY=gemma4:26b-a4b-it-qat
MODEL_SYNTHESIS=gemma4:26b-a4b-it-qat
MODEL_VISION=qwen3-vl:4b
MODEL_FALLBACK=qwen3.5:4b
EMBEDDING_MODEL=qwen3-embedding:0.6b

# MCP server. The app calls tools/list live and only uses available tools.
MCP_ENABLED=true
MCP_SERVER_URL=https://mcp.home.arpa/mcp
MCP_TIMEOUT_SECONDS=75
MCP_VERIFY_TLS=false
MCP_FOLLOW_REDIRECTS=true
MCP_PROTOCOL_VERSION=2025-03-26

# Tool/query behavior.
DEFAULT_SEARCH_RESULTS=8
DEFAULT_SCRAPE_PAGES=4
MAX_TOOL_CALLS=4
MAX_TOOL_CHARS=18000
MAX_REFERENCES=8
ANSWER_REFERENCE_LIMIT=3
MAX_SUBQUERIES=6
ENABLE_LLM_QUERY_PLANNING=true
SEARCH_UNKNOWN_OR_FRESH=true
DEFAULT_NEWS_LOOKBACK_DAYS=7
DEFAULT_FORECAST_DAYS=7

# In-memory session history.
SESSION_HISTORY_MESSAGES=12
MAX_HISTORY_MESSAGE_CHARS=1600

# Future integrations.
DATABASE_URL=
REDIS_URL=

# CORS. Use comma-separated origins for production, for example:
# CORS_ALLOW_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOW_ORIGINS=*

# Default assistant behavior. Override later as your product prompt matures.
DEFAULT_SYSTEM_PROMPT=You are a precise local assistant. Use live tool evidence when needed. Be honest about uncertainty. Keep answers clean, broad, and easy to understand. Put references in a separate section when available.
