# Host binding
HOST_BIND=127.0.0.1
APP_PORT=8001

# Application
APP_NAME=LangChain LangGraph App
ENVIRONMENT=local
LOG_LEVEL=INFO
API_KEY=
CORS_ALLOW_ORIGINS=*

# Ollama
LLM_BACKEND=ollama
OLLAMA_BASE_URL=http://ollama.home.arpa:11434
OLLAMA_TIMEOUT_SECONDS=180
OLLAMA_CONNECT_TIMEOUT_SECONDS=10
OLLAMA_POOL_TIMEOUT_SECONDS=30
OLLAMA_MAX_CONNECTIONS=20
OLLAMA_MAX_KEEPALIVE_CONNECTIONS=10
OLLAMA_MAX_CONCURRENCY=2
OLLAMA_HEAVY_MAX_CONCURRENCY=1
OLLAMA_KEEP_ALIVE=10m
OLLAMA_NUM_PREDICT=2048
OLLAMA_THINK=false
HTTP_KEEPALIVE_EXPIRY_SECONDS=30

MODEL_PLANNER=qwen3.5:4b
MODEL_SIMPLE=qwen3.5:2b
MODEL_GENERAL=qwen3.5:4b
MODEL_SEARCH=qwen3.5:9b
MODEL_REASONING=deepseek-r1:8b
MODEL_FAST_REASONING=phi4-mini-reasoning:latest
MODEL_HEAVY=gemma4:26b-a4b-it-qat
MODEL_SYNTHESIS=gemma4:12b-it-qat
MODEL_WRITER=gemma4:e4b-it-qat
MODEL_CLASSIFIER=gemma4:e2b-it-qat
MODEL_VISION=qwen3-vl:4b
EMBEDDING_MODEL=qwen3-embedding:0.6b
MODEL_FALLBACK=granite3.3:8b

# MCP
MCP_ENABLED=true
MCP_SERVER_URL=https://mcp.home.arpa/mcp
MCP_VERIFY_TLS=false
MCP_FOLLOW_REDIRECTS=true
MCP_TIMEOUT_SECONDS=60
MCP_CONNECT_TIMEOUT_SECONDS=10
MCP_POOL_TIMEOUT_SECONDS=20
MCP_MAX_CONNECTIONS=30
MCP_MAX_KEEPALIVE_CONNECTIONS=15
MCP_MAX_CONCURRENCY=6
MCP_SESSION_ENABLED=true
MCP_INITIALIZE_ON_STARTUP=true
MCP_PROTOCOL_VERSION=2025-06-18
MCP_CLIENT_NAME=langchain-langraph-app

# Inventory cache
INVENTORY_CACHE_TTL_SECONDS=60
INVENTORY_STALE_IF_ERROR_SECONDS=300

# Worker-verifier graph
PHASE2_MAX_ITERATIONS=4
PHASE2_MAX_RESEARCH_ROUNDS=2
PHASE2_MAX_REPLANS=1
PHASE2_MAX_CONTEXT_CHARS=16000

# Global execution budgets
EXECUTION_MAX_DURATION_SECONDS=180
EXECUTION_MAX_MODEL_CALLS=8
EXECUTION_MAX_TOOL_CALLS=10
EXECUTION_MAX_VERIFIER_ROUNDS=3

# Bounded process-local state
STATE_TTL_SECONDS=3600
STATE_MAX_SESSIONS=1000
STATE_MAX_HISTORY_MESSAGES=30

# Phase 3 controls
SIDE_EFFECT_POLICY_ENABLED=true
REAL_STREAMING_ENABLED=true
DETAILED_TRACING_ENABLED=true
EXPOSE_INTERNAL_HEALTH_DETAILS=false

# Phase 4 only; intentionally unused in Phase 3
DATABASE_URL=
REDIS_URL=
