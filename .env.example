# Existing host binding for Caddy/server setup
HOST_BIND=127.0.0.1
APP_PORT=8001

# Application
APP_NAME=LangChain LangGraph App
APP_VERSION=0.6.0-phase1
ENVIRONMENT=local
LOG_LEVEL=INFO
API_KEY=
CORS_ALLOW_ORIGINS=*

# LLM backend
LLM_BACKEND=ollama
OLLAMA_BASE_URL=http://ollama.home.arpa:11434
OLLAMA_TIMEOUT_SECONDS=240
OLLAMA_CONNECT_TIMEOUT_SECONDS=10
OLLAMA_POOL_TIMEOUT_SECONDS=30
OLLAMA_MAX_CONNECTIONS=20
OLLAMA_MAX_KEEPALIVE_CONNECTIONS=10
OLLAMA_MAX_CONCURRENT_REQUESTS=2
OLLAMA_MAX_CONCURRENT_HEAVY_REQUESTS=1
OLLAMA_TEMPERATURE=0.1
OLLAMA_NUM_PREDICT=2048
OLLAMA_STREAM_NUM_PREDICT=2048
OLLAMA_KEEP_ALIVE=10m
OLLAMA_THINK=false
HTTP_KEEPALIVE_EXPIRY_SECONDS=30

# Model routing
MODEL_PLANNER=qwen3.5:4b
MODEL_SIMPLE=qwen3.5:2b
MODEL_GENERAL=qwen3.5:4b
MODEL_SEARCH=qwen3.5:9b
MODEL_REASONING=deepseek-r1:8b
MODEL_FAST_REASONING=phi4-mini-reasoning:latest
MODEL_HEAVY=gemma4:26b-a4b-it-qat
MODEL_SYNTHESIS=gemma4:12b-it-qat
MODEL_WRITER=gemma4:e4b-it-qat
MODEL_CLASSIFIER=gemma4:e2b-it-qat
MODEL_VISION=qwen3-vl:4b
MODEL_FALLBACK=granite3.3:8b
EMBEDDING_MODEL=qwen3-embedding:0.6b

# MCP streamable HTTP session
MCP_ENABLED=true
MCP_SERVER_URL=https://mcp.home.arpa/mcp
MCP_VERIFY_TLS=false
MCP_FOLLOW_REDIRECTS=true
MCP_PROTOCOL_VERSION=2025-03-26
MCP_SESSION_ENABLED=true
MCP_INITIALIZE_ON_STARTUP=false
MCP_CLIENT_NAME=app.local
MCP_CLIENT_VERSION=0.6.0-phase1
MCP_TIMEOUT_SECONDS=75
MCP_CONNECT_TIMEOUT_SECONDS=10
MCP_READ_TIMEOUT_SECONDS=75
MCP_WRITE_TIMEOUT_SECONDS=30
MCP_POOL_TIMEOUT_SECONDS=30
MCP_MAX_CONNECTIONS=20
MCP_MAX_KEEPALIVE_CONNECTIONS=10

# Runtime inventory cache
INVENTORY_CACHE_TTL_SECONDS=30
INVENTORY_STALE_IF_ERROR_SECONDS=300

# Tool/query behavior
DEFAULT_SEARCH_RESULTS=8
DEFAULT_SCRAPE_PAGES=4
MAX_TOOL_CALLS=4
MAX_TOOL_CHARS=18000
MAX_REFERENCES=8
ANSWER_REFERENCE_LIMIT=3
MAX_SUBQUERIES=10
ENABLE_LLM_QUERY_PLANNING=true
SEARCH_UNKNOWN_OR_FRESH=true
DEFAULT_NEWS_LOOKBACK_DAYS=7
DEFAULT_FORECAST_DAYS=7
MIN_ANSWER_CHARS=80
MAX_ANSWER_RETRIES=2

# Bounded process-local conversation memory. No database writes in Phase 1.
SESSION_HISTORY_MESSAGES=12
MAX_HISTORY_MESSAGE_CHARS=1600
MAX_CONVERSATION_SESSIONS=500
CONVERSATION_SESSION_TTL_SECONDS=21600
CONVERSATION_CLEANUP_INTERVAL_SECONDS=300

# Reserved optional database endpoints; disabled/not used by Phase 1.
DATABASE_URL=
REDIS_URL=
NEO4J_URI=
MINIO_ENDPOINT=

# Phase variables for Phase 2 agentic workflow. No database is used.
PHASE2_MAX_ITERATIONS=4
PHASE2_MAX_RESEARCH_ROUNDS=2
PHASE2_MAX_REPLANS=1
PHASE2_MAX_CONTEXT_CHARS=16000
