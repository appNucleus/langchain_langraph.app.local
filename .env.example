# Existing host binding. Keep this for your current Caddy/server setup.
HOST_BIND=127.0.0.1
APP_PORT=8001

# App metadata
APP_NAME=LangChain LangGraph App
APP_VERSION=0.1.0
ENVIRONMENT=local
LOG_LEVEL=INFO

# Optional public API protection.
# If API_KEY is empty, /api/chat is open to whoever can reach the service.
API_KEY=

# LLM backend.
# Keep echo for first deployment smoke tests.
# Change to ollama when your Ollama server/model is reachable.
LLM_BACKEND=ollama
OLLAMA_BASE_URL=http://ollama.home.arpa:11434
MCP_ENABLED=true
MCP_SERVER_URL=https://mcp.home.arpa/mcp
MCP_VERIFY_TLS=false
OLLAMA_MODEL=qwen2.5:0.5b
OLLAMA_TEMPERATURE=0.2
OLLAMA_TIMEOUT_SECONDS=120

# Future integrations.
# If MCP and Ollama run on the same Docker host, host.docker.internal works because compose.yaml adds host-gateway.
# If they run on another server, replace with that server's LAN URL/IP.
MCP_SERVER_URL=http://host.docker.internal:8002/mcp
DATABASE_URL=
REDIS_URL=

# CORS. Use comma-separated origins for production, for example:
# CORS_ALLOW_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOW_ORIGINS=*

# Default assistant behavior. Override later as your product prompt matures.
DEFAULT_SYSTEM_PROMPT=You are a precise, helpful assistant. Answer directly and be honest when a tool, database, or model is not configured yet.
